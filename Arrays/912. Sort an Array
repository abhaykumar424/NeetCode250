class Solution {
public:
    vector<int> sortArray(vector<int>& nums) {
        int mini = INT_MAX;
        int maxi = INT_MIN;
        unordered_map<int, int>mp;
        for(int i=0; i<nums.size(); i++){
            mini = min(mini, nums[i]);
            maxi = max(maxi, nums[i]);
            mp[nums[i]]++;
        }
        int cnt = 0;
        for(int i=mini; i<=maxi; i++){
            while(mp[i]>0){
                nums[cnt] = i;
                cnt++;
                mp[i]--;
            }

        }
        return nums;
    }
};