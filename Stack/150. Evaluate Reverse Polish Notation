class Solution {
public:
    int evalRPN(vector<string>& tokens) {
        stack<string>st;
        
        int n = tokens.size();
        for(int i =0; i<n; i++){
            if(tokens[i]=="+"){
                int num1 = stoi(st.top());
                st.pop();
                int num2 = stoi(st.top());
                st.pop();
                int temp = num1 + num2;
                st.push(to_string(temp));
            }
            else if(tokens[i]=="-"){
                int num1 = stoi(st.top());
                st.pop();
                int num2 = stoi(st.top());
                st.pop();
                int temp = num2 - num1;
                st.push(to_string(temp));
            }
            else if(tokens[i]=="*"){
                int num1 = stoi(st.top());
                st.pop();
                int num2 = stoi(st.top());
                st.pop();
                int temp = num1 * num2;
                st.push(to_string(temp));
            }
            else if(tokens[i]=="/"){
                int num1 = stoi(st.top());
                st.pop();
                int num2 = stoi(st.top());
                st.pop();
                int temp = num2 / num1;
                st.push(to_string(temp));
            }
            else st.push(tokens[i]);
        }
        return stoi(st.top());
    }
};