class Solution {
public:
    int calPoints(vector<string>& operations) {
        stack<int>st;
        for(int i=0; i<operations.size(); i++){
            if(operations[i]=="C"){
                st.pop();
            }
            else if(operations[i]=="D"){
                int num = st.top()*2;
                st.push(num);

            }
            else if(operations[i]=="+"){
                int num1 = st.top();
                st.pop();
                int num2 = st.top();
                st.push(num1);
                int num3 = num1+num2;
                st.push(num3);
            }
            else{
                int num = stoi(operations[i]);
                st.push(num);
            }
        }
        int ans = 0;
        while(!st.empty()){
            ans+=st.top();
            st.pop();
        }
        return ans;
    }
};