class Solution {
public:

    void dfs(vector<string> &ans,string &str, int startN, int endN, int n){
        if(startN==n && startN==endN){
            ans.push_back(str);
            return;
        }
        if(startN<n){
            str+='(';
            dfs(ans, str, startN + 1, endN, n);
            str.pop_back();
        }
     
        if(startN>endN){
            str+=')';
            dfs(ans, str, startN, endN + 1, n);
            str.pop_back();
        }
    }
    vector<string> generateParenthesis(int n) {
        vector<string>ans;
        int startN = 0;
        int endN = 0;
        string str = "";
        dfs(ans, str, startN, endN, n);
        return ans;
    }
};