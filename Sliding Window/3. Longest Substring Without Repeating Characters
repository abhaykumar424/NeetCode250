class Solution {
public:
    int lengthOfLongestSubstring(string s) {
        unordered_set<char>temp;
        int left = 0;
        int maxi = 0;
        for(int right = 0; right<s.size(); right++){
            while(temp.find(s[right])!=temp.end()){
                temp.erase(s[left]);
                left++;
            }
            maxi = max(maxi, right-left+1);
            temp.insert(s[right]);
        }
        return maxi;
    }
};