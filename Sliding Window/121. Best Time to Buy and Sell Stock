class Solution {
public:
    int maxProfit(vector<int>& prices) {
        int left  = 0;
        int right = 0;
        int n = prices.size();
        int maxi = 0;
        while(right<n){
            if(prices[left]<prices[right]){
                int profit = prices[right]-prices[left];
                maxi = max(maxi, profit);
            }
            else{
                left = right;
            }
            right++;
        }
        return maxi;
    }
};