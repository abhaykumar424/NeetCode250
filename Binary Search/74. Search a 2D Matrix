class Solution {
public:
    bool searchMatrix(vector<vector<int>>& matrix, int target) {
        int m = matrix.size();
        int n = matrix[0].size();

        int row = 0;
        int col = m*n-1;

        while(row<=col){
            int mid = row +(col-row)/2;
            
            int left = mid/n;
            int right = mid%n;

            int val = matrix[left][right];

            if(val == target) return true;
            else if(val<target) row = mid+1;
            else col = mid-1;
        }
        return false;
    }
};