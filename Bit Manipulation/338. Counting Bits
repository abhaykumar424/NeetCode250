class Solution {
public:

    int check(int num){
        int cnt = 0;
        while(num!=0){
            cnt+= (num&1);
            num = num>>1;
        }
        return cnt;
    }
    vector<int> countBits(int n) {
        vector<int>num;
        for(int i = 0; i<=n; i++){
            int temp = check(i);
            num.push_back(temp);
        }
        return num;
    }
};
