class Solution {
public:
    int reverse(int x) {
        long long temp1 = 0 ;
        while(x!=0){
            int temp2 = x%10;
            temp1 = temp1*10 + temp2;
            x/=10;
        }
        if(temp1<INT_MIN || temp1>INT_MAX){
            return 0;
        }
        return temp1;

    }
};